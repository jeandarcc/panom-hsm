{
  "name": "@panomapp/hsm",
  "version": "1.0.1",
  "description": "Universal hierarchical app state runtime for route, query, policy, backend, browser, and host-aware navigation.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "require": "./dist/schema/index.cjs"
    },
    "./backend": {
      "types": "./dist/backend/index.d.ts",
      "import": "./dist/backend/index.js",
      "require": "./dist/backend/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js",
      "require": "./dist/browser/index.cjs"
    },
    "./runtime": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js",
      "require": "./dist/browser/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.js",
      "require": "./dist/devtools/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/core/index.ts src/schema/index.ts src/backend/index.ts src/browser/index.ts src/vue/index.ts src/devtools/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build && npm pack --dry-run"
  },
  "keywords": [
    "hsm",
    "state-machine",
    "hierarchical-state-machine",
    "router",
    "state-router",
    "route-projection",
    "url-state",
    "query-state",
    "typescript",
    "web-app",
    "transition-runtime",
    "loader",
    "lifecycle",
    "schema",
    "backend",
    "universal-runtime",
    "contract",
    "express",
    "policy-engine",
    "permissions",
    "feature-flags",
    "capabilities",
    "browser-history",
    "url-sync",
    "subdomain-policy",
    "host-aware-routing",
    "canonical-navigation",
    "redirect-safety",
    "vue",
    "devtools",
    "schema-driven",
    "frontend-backend-contract"
  ],
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "vue": "^3.5.34"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@panomapp/subdomain-policy": "^0.1.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0 || ^3.5.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/panomapp/panom-hsm.git"
  },
  "bugs": {
    "url": "https://github.com/panomapp/panom-hsm/issues"
  },
  "homepage": "https://github.com/panomapp/panom-hsm#readme"
}
